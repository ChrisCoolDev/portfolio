---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import GridPattern from '../components/GridPattern.astro'
import HeroSection from '../components/HeroSection.astro'
import BlogSection from '../components/BlogSection.astro'
import ProjectsSection from '../components/ProjectsSection.astro'
import ExperienceSection from '../components/ExperienceSection.astro'
import CommunitySection from '../components/CommunitySection.astro'
import SpotifySection from '../components/SpotifySection.astro'
---

<BaseLayout>
  <div class="flex flex-col min-h-screen">
    <div class="w-full max-w-6xl mx-auto px-4 flex-1 sm:px-6 lg:px-8">
      <div class="w-full pb-24">
        <Header />

        <main class="min-h-full mt-10 sm:mt-12">
          <GridPattern />
          <HeroSection />
          <BlogSection />
          <ProjectsSection />

          <div class="mt-10 grid gap-y-8 py-10 sm:gap-x-12 lg:grid-cols-2">
            <div class="space-y-10">
              <ExperienceSection />
              <CommunitySection />
            </div>
            <div class="mt-10 lg:row-span-2 lg:mt-0">
              <SpotifySection />
            </div>
          </div>
        </main>
      </div>
    </div>

    <Footer />
  </div>
</BaseLayout>
