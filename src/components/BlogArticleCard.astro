---
interface Props {
  title: string
  slug: string
  date: string
  dateFormatted: string
  tag?: string
  excerpt: string
  readTime?: number
}

const { title, slug, date, dateFormatted, tag, excerpt, readTime } = Astro.props
---

<article class="group relative flex flex-col items-start">
  <div class="z-50 flex items-center gap-x-4 text-xs">
    <time datetime={date} class="flex items-center text-sm capitalize text-zinc-400 dark:text-zinc-500">
      {dateFormatted}
    </time>
    {tag && (
      <span class="inline-flex items-center bg-zinc-50 px-2 py-1 text-xs font-medium text-zinc-500 ring-1 ring-inset ring-zinc-400/20 dark:bg-zinc-400/10 dark:text-zinc-400">
        {tag}
      </span>
    )}
  </div>
  <div class="mt-1">
    <h2 class="text-lg font-semibold tracking-tight font-heading text-zinc-800 dark:text-zinc-100">
      <div class="absolute z-0 transition scale-95 opacity-0 -inset-x-4 -inset-y-6 bg-zinc-50 group-hover:scale-100 group-hover:opacity-100 sm:-inset-x-6 dark:bg-zinc-800/70"></div>
      <a href={`/blog/${slug}`}>
        <span class="absolute z-20 -inset-x-4 -inset-y-6 sm:-inset-x-6 sm:rounded-2xl"></span>
        <span class="relative z-10">{title}</span>
      </a>
    </h2>
    <p class="relative z-10 mt-4 text-sm text-zinc-600 dark:text-zinc-300/80">
      {excerpt}
    </p>
    <div class="relative z-10 flex items-center mt-4 text-sm gap-x-2 text-zinc-400 dark:text-zinc-300">
      <a href={`/blog/${slug}`} class="inline-flex items-center font-medium text-blue-500 hover:text-blue-600">
        Lire l'article
        <svg viewBox="0 0 16 16" fill="none" aria-hidden="true" class="size-4 ml-1 stroke-current">
          <path d="M6.75 5.75 9.25 8l-2.5 2.25" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </a>
      {readTime && (
        <>
          <span>/</span>
          <span>{readTime} min de lecture</span>
        </>
      )}
    </div>
  </div>
</article>
