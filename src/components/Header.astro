---
import SocialLinks from "./SocialLinks.astro";
import ThemeToggle from "./ThemeToggle.astro";

const navItems = [
  { label: "A propos", href: "/about" },
  { label: "Blog", href: "/blog" },
  { label: "Projets", href: "/projects" },
];
---

<header class="mx-auto max-w-6xl py-8">
  <div class="flex items-center justify-between">
    <div class="relative flex flex-1 items-center">
      <div class="flex flex-1 gap-x-20">
        <!-- Logo -->
        <div
          class="size-10 bg-white/90 p-0.5 shadow-lg shadow-zinc-800/5 ring-1 ring-zinc-900/5 backdrop-blur-sm dark:bg-zinc-800/90 dark:ring-white/10"
        >
          <a href="/" class="block size-full">
            <span class="sr-only">Christian Ludovic</span>
            <img
              class="size-9 object-cover"
              src="https://chrisx01.netlify.app/_next/image?url=%2F_next%2Fstatic%2Fmedia%2FprofilPic.aa5fbad6.png&w=96&q=75"
              alt="Christian Ludovic"
              width="36"
              height="36"
            />
          </a>
        </div>

        <!-- Desktop navigation -->
        <nav class="pointer-events-auto hidden md:block">
          <ul
            id="nav"
            class="flex bg-white/90 px-3 text-sm font-medium text-zinc-800 shadow-lg shadow-zinc-800/5 ring-1 ring-zinc-900/5 backdrop-blur-sm dark:bg-zinc-800/90 dark:text-zinc-200 dark:ring-white/10"
          >
            {
              navItems.map((item) => (
                <li>
                  <a
                    class="relative block px-3 py-2 transition hover:text-blue-500 dark:hover:text-white"
                    href={item.href}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>

      <!-- Mobile menu -->
      <div
        x-data="{ open: false }"
        x-on:keydown.window.escape="open = false"
        class="md:hidden"
      >
        <button
          x-on:click="open = true"
          class="group flex items-center bg-white/90 px-4 py-2 text-sm font-medium text-zinc-800 shadow-lg shadow-zinc-800/5 ring-1 ring-zinc-900/5 backdrop-blur-sm dark:bg-zinc-800/90 dark:text-zinc-200 dark:ring-white/10 dark:hover:ring-white/20"
          type="button"
          aria-expanded="false"
          id="popover-button"
        >
          Menu
          <svg
            viewBox="0 0 8 6"
            aria-hidden="true"
            class="ml-3 h-auto w-2 stroke-zinc-500 group-hover:stroke-zinc-400"
          >
            <path
              d="M1.75 1.75 4 4.25l2.25-2.5"
              fill="none"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>
        <div x-show="open" style="display: none;">
          <div
            x-show="open"
            x-transition:enter="duration-200 ease-out"
            x-transition:enter-start="scale-95 opacity-0"
            x-transition:enter-end="scale-100 opacity-100"
            x-transition:leave="duration-100 ease-in"
            x-transition:leave-start="scale-100 opacity-100"
            x-transition:leave-end="scale-95 opacity-0"
            class="fixed inset-x-4 top-8 z-50 origin-top-right transform transition"
            style="display: none;"
          >
            <div
              class="bg-white p-8 ring-1 ring-zinc-900/5 dark:bg-zinc-900 dark:ring-zinc-800"
            >
              <div class="flex flex-row-reverse items-center justify-between">
                <button
                  x-on:click="open = false"
                  aria-label="Close menu"
                  class="-m-1 p-1"
                  type="button"
                >
                  <svg
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                    class="size-6 text-zinc-400"
                  >
                    <path
                      d="m17.25 6.75-10.5 10.5M6.75 6.75l10.5 10.5"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"></path>
                  </svg>
                </button>
                <h2 class="text-sm font-medium text-zinc-400">Navigation</h2>
              </div>
              <nav class="mt-6 divide-y divide-zinc-100 divide-zinc-100/5">
                <ul class="pb-6 text-base text-zinc-800 dark:text-zinc-300">
                  <li class="-mx-3">
                    <a
                      class="relative block px-3 py-2 transition text-blue-400"
                      href="/"
                    >
                      Accueil
                      <span
                        class="absolute inset-x-1 -bottom-px h-px bg-gradient-to-r from-blue-500/0 via-blue-500/40 to-blue-500/0"
                      ></span>
                    </a>
                  </li>
                  {
                    navItems.map((item) => (
                      <li class="-mx-3">
                        <a
                          class="relative block px-3 py-2 transition hover:text-blue-500 dark:hover:text-white"
                          href={item.href}
                        >
                          {item.label}
                        </a>
                      </li>
                    ))
                  }
                </ul>
                <SocialLinks variant="mobile" />
              </nav>
            </div>
          </div>
          <div
            class="fixed inset-0 z-30 bg-zinc-800/40 backdrop-blur-sm dark:bg-black/80"
          >
          </div>
        </div>
      </div>
    </div>

    <div class="flex items-center">
      <SocialLinks variant="desktop" />
      <ThemeToggle />
    </div>
  </div>
</header>
