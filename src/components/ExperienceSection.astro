---
import ExperienceItem from './ExperienceItem.astro'

const experiences = [
  {
    company: 'UpWork',
    role: 'Freelance Front-end Developer',
    startDate: 'Jul. 2025',
    endDate: 'Présent',
    logo: 'upwork' as const,
    logoImg: '/logos/upwork.png',
  },
  {
    company: 'Yb_digitall',
    role: 'Front-end Developer',
    startDate: 'Dec. 2024',
    endDate: 'Fev. 2025',
    logo: 'ybdigitall' as const,
    logoImg: '/logos/yb_digitall.jpeg',
  },
  {
    company: 'Ejara Cameroun',
    role: 'Product Designer Junior',
    startDate: 'Oct. 2022',
    endDate: 'Mar. 2023',
    logo: 'ejara' as const,
    logoImg: '/logos/ejara.svg',
  },
  {
    company: 'Glom Sarl Cameroun',
    role: 'Web Designer',
    startDate: 'Jan. 2022',
    endDate: 'Jul. 2022',
    logo: 'glom' as const,
    logoImg: '/logos/glom.png',
  },
]
---

<div class="p-6 ring-1 ring-zinc-200/70 dark:ring-zinc-700/40">
  <h2 class="flex items-center text-sm font-semibold font-heading text-zinc-900 dark:text-zinc-100">
    <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="flex-none w-6 h-6">
      <path d="M2.75 9.75a3 3 0 0 1 3-3h12.5a3 3 0 0 1 3 3v8.5a3 3 0 0 1-3 3H5.75a3 3 0 0 1-3-3v-8.5Z" class="fill-zinc-100/10 stroke-zinc-500"></path>
      <path d="M3 14.25h6.249c.484 0 .952-.002 1.316.319l.777.682a.996.996 0 0 0 1.316 0l.777-.682c.364-.32.832-.319 1.316-.319H21M8.75 6.5V4.75a2 2 0 0 1 2-2h2.5a2 2 0 0 1 2 2V6.5" class="stroke-zinc-500"></path>
    </svg>
    <span class="ml-3">Expériences</span>
  </h2>
  <ol class="mt-6 space-y-4">
    {experiences.map(exp => (
      <ExperienceItem {...exp} />
    ))}
  </ol>
  <a class="group mt-10 inline-flex w-full items-center justify-center bg-zinc-50 ring-1 ring-zinc-100 px-3 py-2.5 text-sm font-medium text-zinc-900 outline-offset-2 transition hover:bg-zinc-100 hover:text-zinc-700 dark:bg-zinc-800/50 dark:text-zinc-300 dark:hover:bg-zinc-800 dark:ring-white/10 dark:hover:text-zinc-50" href="mailto:hello@chrisx01.dev">
    Me contacter
  </a>
</div>
