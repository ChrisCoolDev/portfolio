---
interface Props {
  company: string
  role: string
  startDate: string
  endDate?: string
  isMission?: boolean
  logo: string
  logoImg?: string
}

const { company, role, startDate, endDate, isMission = false, logo, logoImg } = Astro.props

// Generate initials from company name for fallback
const initials = company.split(' ').map(w => w[0]).join('').slice(0, 2).toUpperCase()
---

<li class="flex gap-4">
  <div class="relative flex items-center justify-center flex-none size-10 shadow-md shadow-zinc-800/5 ring-1 ring-zinc-900/5 dark:border dark:border-zinc-700/50 dark:bg-zinc-800 dark:ring-0 bg-white">
    {logoImg ? (
      <img src={logoImg} class="size-7 object-contain" alt={`${company} Logo`} />
    ) : (
      <span class="text-xs font-bold text-zinc-500 dark:text-zinc-400">{initials}</span>
    )}
  </div>
  <dl class="flex flex-auto flex-wrap gap-x-2">
    <dt class="sr-only">Entreprise</dt>
    <dd class="w-full flex-none text-sm font-medium text-zinc-900 dark:text-zinc-100">
      {company}
      {isMission && (
        <span class="ml-1 text-xs text-zinc-400 dark:text-zinc-500">(Mission)</span>
      )}
    </dd>
    <dt class="sr-only">Poste</dt>
    <dd class="text-xs text-zinc-500 dark:text-zinc-400">{role}</dd>
    <dt class="sr-only">Dates</dt>
    <dd class="ml-auto text-xs text-zinc-400 dark:text-zinc-500" aria-label={`${startDate} à ${endDate || 'Présent'}`}>
      <time>{startDate}</time>
      <span aria-hidden="true">—</span>
      <time>{endDate || 'Présent'}</time>
    </dd>
  </dl>
</li>
