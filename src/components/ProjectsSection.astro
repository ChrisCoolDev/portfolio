---
import ProjectCard from './ProjectCard.astro'
import { projects as allProjects } from '../data/projects'

// Affiche les 3 projets les plus récents sur la page d'accueil
const projects = allProjects.slice(0, 3)
---

<div>
  <h2 class="text-2xl font-semibold font-heading text-zinc-900 dark:text-white lg:text-3xl">
    Mes projets
  </h2>
  <p class="mt-3 text-zinc-600 dark:text-zinc-300/80">
    Voici une petite liste des projets que j'ai réalisé et auxquels j'ai participé.
  </p>
</div>

<div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 lg:gap-x-8">
  {projects.map(project => (
    <ProjectCard {...project} />
  ))}
</div>

<div class="mt-10 max-w-2xl lg:mt-16">
  <p class="text-lg text-zinc-600 dark:text-zinc-300/80">
    Les projets auxquels j'ai participé. Vous pouvez
    obtenir une liste plus exhaustive en visitant la page de tous les projets.
  </p>
  <div class="my-8 border-t border-zinc-200 dark:border-zinc-800"></div>
  <a href="/projects" class="inline-flex gap-2 py-6 font-medium text-zinc-700 hover:text-zinc-950 hover:underline dark:text-zinc-300 dark:hover:text-white">
    Voir tous les projets <span aria-hidden="true">→</span>
  </a>
</div>
