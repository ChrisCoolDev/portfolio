---
import ProjectCard from './ProjectCard.astro'

const projects = [
  {
    title: 'Subscribe',
    href: '#',
    image: 'https://chrisx01.netlify.app/projects_images/subscribeThumbnail.png',
    techStack: 'Laravel, React, Tailwindcss',
    description: "Design and participation in the integration of the web application Subscribe, which allows users to easily manage their subscriptions (Netflix, Spotify, Deezer, etc.).",
    type: 'side-project' as const,
  },
  {
    title: 'Haku Studio',
    href: '#',
    image: 'https://chrisx01.netlify.app/projects_images/hakuThumbnail.png',
    techStack: 'React, Tailwindcss',
    description: "Design and integration of the landing page of a creative agency studio called Haku.Studio.",
    type: 'client' as const,
  },
  {
    title: 'Yeezy Webapp Clone',
    href: '#',
    image: 'https://chrisx01.netlify.app/projects_images/yeezyThumbnail.png',
    techStack: 'Vue, Tailwind, jspdf, htmltocanvas',
    description: "Built the clone of the entire process of Yeezy e-commerce webapp, with features like receipt generation in PDF.",
    type: 'side-project' as const,
  },
]
---

<div>
  <h2 class="text-2xl font-semibold font-heading text-zinc-900 dark:text-white lg:text-3xl">
    Mes projets
  </h2>
  <p class="mt-3 text-zinc-600 dark:text-zinc-300/80">
    Voici une petite liste des projets que j'ai réalisé et auxquels j'ai participé.
  </p>
</div>

<div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 lg:gap-x-8">
  {projects.map(project => (
    <ProjectCard {...project} />
  ))}
</div>

<div class="mt-10 max-w-2xl lg:mt-16">
  <p class="text-lg text-zinc-600 dark:text-zinc-300/80">
    Les projets auxquels j'ai participé. Vous pouvez
    obtenir une liste plus exhaustive en visitant la page de tous les projets.
  </p>
  <div class="my-8 border-t border-zinc-200 dark:border-zinc-800"></div>
  <a href="/projects" class="inline-flex gap-2 py-6 font-medium text-zinc-700 hover:text-zinc-950 hover:underline dark:text-zinc-300 dark:hover:text-white">
    Voir tous les projets <span aria-hidden="true">→</span>
  </a>
</div>
