---
interface Props {
  variant?: "desktop" | "mobile";
}

const { variant = "desktop" } = Astro.props;

const links = [
  {
    href: "https://www.linkedin.com/in/worldbychris/",
    label: "LinkedIn",
    hoverColor: "hover:text-[#0a66c2]",
  },
  {
    href: "https://github.com/ChrisCoolDev",
    label: "GitHub",
    hoverColor: "hover:text-zinc-900 dark:hover:text-[#fafafa]",
  },
];
---

<div
  class={`flex-wrap space-x-4 ${variant === "desktop" ? "hidden items-center lg:flex" : "flex items-center"}`}
>
  {
    links.map((link) => (
      <a href={link.href} class={`text-zinc-500 transition ${link.hoverColor}`}>
        <span class="sr-only">{link.label}</span>
        {link.label === "LinkedIn" && (
          <svg
            aria-hidden="true"
            class="size-6"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 256 256"
            fill="currentColor"
          >
            <path
              d="M224,40V216a8,8,0,0,1-8,8H40a8,8,0,0,1-8-8V40a8,8,0,0,1,8-8H216A8,8,0,0,1,224,40Z"
              opacity="0.2"
            />
            <path d="M216,24H40A16,16,0,0,0,24,40V216a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V40A16,16,0,0,0,216,24Zm0,192H40V40H216V216ZM96,112v64a8,8,0,0,1-16,0V112a8,8,0,0,1,16,0Zm88,28v36a8,8,0,0,1-16,0V140a20,20,0,0,0-40,0v36a8,8,0,0,1-16,0V112a8,8,0,0,1,15.79-1.78A36,36,0,0,1,184,140ZM100,84A12,12,0,1,1,88,72,12,12,0,0,1,100,84Z" />
          </svg>
        )}
        {link.label === "GitHub" && (
          <svg
            class="size-6"
            aria-hidden="true"
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              fill-rule="evenodd"
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              clip-rule="evenodd"
            />
          </svg>
        )}
      </a>
    ))
  }
  <a
    href="mailto:talchrist10@gmail.com"
    class="inline-block bg-white/90 px-3 py-2 text-sm font-medium leading-5 shadow-lg shadow-zinc-800/5 ring-1 ring-zinc-900/5 backdrop-blur-sm transition dark:bg-zinc-800/90 dark:text-zinc-200 dark:ring-white/10 dark:hover:ring-white/20"
  >
    <span class="sr-only">Adresse E-mail</span>
    Par Mail
  </a>
</div>
