---
interface Props {
  title: string
  href: string
  date: string
  dateFormatted: string
  tag?: string
  tagHref?: string
  excerpt: string
  image: string
}

const { title, href, date, dateFormatted, tag, tagHref, excerpt, image } = Astro.props
---

<div class="lg:row-span-3">
  <article>
    <div class="relative mb-8 w-full">
      <img src={image} alt="Article thumbnail" class="aspect-[16/9] w-full bg-zinc-100 object-cover dark:bg-zinc-800 sm:aspect-[2/1]" />
      <div class="absolute inset-0 ring-1 ring-inset ring-gray-900/10"></div>
    </div>

    <div class="flex items-center gap-x-4 text-xs">
      <time datetime={date} class="block text-sm capitalize leading-6 text-zinc-500 dark:text-zinc-400">
        {dateFormatted}
      </time>
      {tag && tagHref && (
        <a href={tagHref} class="inline-flex items-center bg-zinc-50 px-2 py-1 text-xs font-medium text-zinc-500 ring-1 ring-inset ring-zinc-400/20 hover:text-zinc-700 hover:ring-zinc-400/20 dark:bg-zinc-400/10 dark:text-zinc-400 dark:hover:text-white dark:hover:ring-white/20">
          {tag}
        </a>
      )}
    </div>
    <h2 id="featured-post" class="mt-4 text-xl font-bold font-heading tracking-tight text-zinc-900 dark:text-white sm:text-2xl">
      {title}
    </h2>
    <p class="mt-4 leading-7 text-zinc-600 dark:text-zinc-400">
      {excerpt}
    </p>
    <div class="mt-4 flex flex-col justify-between gap-6 sm:mt-8 sm:flex-row-reverse sm:gap-8 lg:mt-4 lg:flex-col">
      <div class="flex">
        <a href={href} class="text-sm font-semibold leading-6 text-blue-500 hover:text-blue-600" aria-describedby="featured-post">
          Lire l'article
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </article>
</div>
